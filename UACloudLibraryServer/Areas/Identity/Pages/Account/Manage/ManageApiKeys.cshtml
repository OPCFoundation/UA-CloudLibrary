@page
@model ManageApiKeysModel
@{
    ViewData["Title"] = "Manage API Keys";
    ViewData["ActivePage"] = ManageNavPages.ManageApiKeys;
}

<h3>@ViewData["Title"]</h3>
<partial name="_StatusMessage" for="StatusMessage" />
<div class="row">
	@if (!string.IsNullOrEmpty(Model.GeneratedApiKey))
	{
		<div class="col-md-12 mb-4">
			<div class="alert alert-success shadow-sm border-0" role="alert">
				<div class="d-flex align-items-center mb-3">
					<i class="bi bi-check-circle-fill fs-3 me-3"></i>
					<h4 class="mb-0">API Key Successfully Generated!</h4>
				</div>

				<div class="card bg-white">
					<div class="card-body">
						<div class="mb-3">
							<label class="form-label fw-bold text-dark">
								<i class="bi bi-tag-fill me-1"></i>Name:
							</label>
							<div class="input-group">
								<input type="text" class="form-control bg-light" value="@Model.GeneratedApiKeyName" readonly />
							</div>
						</div>

						<div class="mb-3">
							<label class="form-label fw-bold text-dark">
								<i class="bi bi-key-fill me-1"></i>API Key:
							</label>
							<div class="input-group">
								<input type="text" id="generatedApiKey" class="form-control font-monospace bg-light" value="@Model.GeneratedApiKey" readonly />
								<button class="btn btn-outline-primary" type="button" onclick="copyApiKey()">
									<i class="bi bi-clipboard"></i> Copy
								</button>
							</div>
						</div>

						<div class="alert alert-warning mb-0" role="alert">
							<i class="bi bi-exclamation-triangle-fill me-2"></i>
							<strong>Important:</strong> Save this API key now! You won't be able to retrieve it later.
						</div>
					</div>
				</div>

				<div class="mt-3 p-3 bg-light rounded">
					<h6 class="fw-bold">
						<i class="bi bi-info-circle-fill me-1"></i>Usage Instructions:
					</h6>
					<p class="mb-0 small">
						Add an HTTP Header <code>X-Api-Key</code> with the API key as the header value.
						The key name does not need to be provided separately for authentication.
					</p>
				</div>
			</div>
		</div>
	}
	<div class="col-md-6 pt-2">
		<div class="card shadow-sm">
			<div class="card-header bg-primary text-white">
				<h4 class="mb-0">
					<i class="bi bi-key-fill me-2"></i>Generate a New API Key
				</h4>
			</div>
			<div class="card-body">
				<div class="alert alert-info" role="alert">
					<i class="bi bi-info-circle-fill me-2"></i>
					<strong>About API Keys:</strong> API keys are intended for non-interactive services that need to call the REST API. 
					They have all the permissions of the user who created them, including any Administrator role membership.
				</div>
				<form id="create-api-key-form" method="post">
					<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

					<div class="form-floating mb-3">
						<input asp-for="Input.NewApiKeyName" class="form-control" placeholder="My API Key" aria-required="true" />
						<label asp-for="Input.NewApiKeyName" class="form-label">
							<i class="bi bi-tag-fill me-1"></i>API Key Name
						</label>
						<span asp-validation-for="Input.NewApiKeyName" class="text-danger"></span>
					</div>

					<div class="mb-3">
						<label asp-for="Input.ApiKeyType" class="form-label fw-bold">
							<i class="bi bi-shield-lock-fill me-1"></i>API Key Type
						</label>
						<select asp-for="Input.ApiKeyType" class="form-select form-select-lg" aria-required="true">
							<option value="" disabled selected>Select API Key Type</option>
							<option value="Read-Only">🔒 Read-Only</option>
							<option value="Read-Write">🔓 Read-Write</option>
						</select>
						<span asp-validation-for="Input.ApiKeyType" class="text-danger"></span>
						<div class="form-text">
							<small>Read-Only keys can only retrieve data, while Read-Write keys can modify data.</small>
						</div>
					</div>

					<div class="mb-4">
						<label asp-for="Input.Expiration" class="form-label fw-bold">
							<i class="bi bi-calendar-event-fill me-1"></i>Expiration
						</label>
						<select asp-for="Input.Expiration" class="form-select form-select-lg" aria-required="true">
							<option value="" disabled selected>Select Expiration Period</option>
							<option value="Unlimited">♾️ Unlimited (No Expiration)</option>
							<option value="1 Day">📅 1 Day</option>
							<option value="30 Days">📅 30 Days</option>
							<option value="6 Month">📅 6 Months</option>
							<option value="1 Year">📅 1 Year</option>
						</select>
						<span asp-validation-for="Input.Expiration" class="text-danger"></span>
						<div class="form-text">
							<small>Shorter expiration periods are more secure. Unlimited keys never expire.</small>
						</div>
					</div>

					<div class="d-grid">
						<button type="submit" class="btn btn-primary btn-lg">
							<i class="bi bi-plus-circle-fill me-2"></i>Generate API Key
						</button>
					</div>
				</form>
			</div>
		</div>
	</div>
    @if (Model.ApiKeysAndNames?.Any() == true)
    {
        <div class="col-md-6 pt-2">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-list-ul me-2"></i>Existing API Keys
                    </h4>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var apiKeyAndName in Model.ApiKeysAndNames)
                        {
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between align-items-center">
                                    <div class="flex-grow-1">
                                        <h6 class="mb-1 fw-bold">
                                            <i class="bi bi-key me-1"></i>@apiKeyAndName.KeyName
                                        </h6>
                                        <p class="mb-0 text-muted small font-monospace">
                                            <i class="bi bi-shield-lock me-1"></i>@apiKeyAndName.KeyPrefix...
                                        </p>
                                    </div>
                                    <div>
                                        <form asp-page-handler="DeleteApiKey" method="post" id="@($"remove-login-{apiKeyAndName.KeyName}")" style="display:inline;">
                                            <input asp-for="@apiKeyAndName.KeyName" name="ApiKeyToDelete" type="hidden" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm" 
                                                    title="Remove API key @apiKeyAndName.KeyName"
                                                    onclick="return confirm('Are you sure you want to delete the API key \'@apiKeyAndName.KeyName\'?');">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function copyApiKey() {
            var apiKeyInput = document.getElementById('generatedApiKey');
            apiKeyInput.select();
            apiKeyInput.setSelectionRange(0, 99999); // For mobile devices
            navigator.clipboard.writeText(apiKeyInput.value).then(function() {
                // Show success feedback
                var btn = event.target.closest('button');
                var originalHtml = btn.innerHTML;
                btn.innerHTML = '<i class="bi bi-check-circle-fill"></i> Copied!';
                btn.classList.remove('btn-outline-primary');
                btn.classList.add('btn-success');
                setTimeout(function() {
                    btn.innerHTML = originalHtml;
                    btn.classList.remove('btn-success');
                    btn.classList.add('btn-outline-primary');
                }, 2000);
            });
        }
    </script>
}
